# Airlock configuration (copy to .env or export). All optional — sane defaults shown.

# --- policy (the only things that ever leave the machine) ---
AIRLOCK_EGRESS_DOMAIN=https://www.google.com   # the ONLY domain Airlock will navigate to
AIRLOCK_SEARCH_PATH=/search?q={q}
AIRLOCK_RESULT_SELECTOR=div#search a:has(h3)
AIRLOCK_ALLOW_FETCH=1                           # 0 = search-only (no page fetch)
AIRLOCK_MAX_RESULTS=10
AIRLOCK_PORT=9100

# --- the dedicated Chrome Airlock drives over CDP ---
CHROME_CDP_URL=http://localhost:9222
CHROME_BIN=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROME_PROFILE=~/airlock-chrome-profile        # dedicated, logged-in profile
CHROME_DEBUG_PORT=9222
